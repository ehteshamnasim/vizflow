{
  "name": "vizflow",
  "version": "0.9.3",
  "description": "VizFlow - A powerful visual workflow builder with 80+ nodes, API testing, and full execution engine. Build, test, and export automation workflows.",
  "main": "dist/vizflow.umd.js",
  "module": "dist/vizflow.es.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vizflow.es.js",
      "require": "./dist/vizflow.umd.js",
      "types": "./src/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src/index.d.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "BUILD_MODE=lib vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "keywords": [
    "workflow",
    "flowchart",
    "diagram",
    "drawflow",
    "node-editor",
    "visual-programming",
    "drag-drop",
    "no-code",
    "automation",
    "api-testing"
  ],
  "author": "Ehtesham",
  "license": "MIT",
  "homepage": "https://github.com/ehtesham/flowkit#readme",
  "bugs": {
    "url": "https://github.com/ehtesham/flowkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ehtesham/flowkit.git"
  },
  "dependencies": {
    "drawflow": "^0.0.60"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
